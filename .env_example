# Google Gemini API Key
GOOGLE_API_KEY=your_google_api_key_here

# Mastra Observability Platform Configuration
MASTRA_PLATFORM_ACCESS_TOKEN=your_mastra_platform_access_token_here
MASTRA_PROJECT_ID=your_mastra_project_id_here

# PostgreSQL Database Connection String (e.g. Neon, Supabase, local PostgreSQL)
DATABASE_URL=postgresql://user:password@host:port/dbname?sslmode=require

# Server Configuration (Optional)
PORT=3000

DATA_DIR=./data/sample_b